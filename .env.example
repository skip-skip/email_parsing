# Database connection string (SQLAlchemy format)
# For local development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./data.db
# For Docker/production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://aitaskmanager:aitaskmanager@db:5432/aitaskmanager

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=aitaskmanager
POSTGRES_PASSWORD=aitaskmanager
POSTGRES_DB=aitaskmanager

# Ollama API base URL
OLLAMA_BASE_URL=http://localhost:11434

# How often to poll Outlook inbox (in seconds)
POLL_INTERVAL_SECONDS=30

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
